{
  "name": "whatsapp-broadcast-bot",
  "version": "1.0.0",
  "description": "WhatsApp image broadcast bot with caption and rate-limiting using whatsapp-web.js",
  "main": "main.js",
  "scripts": {
    "start": "node index.js",
    "server": "node server.js",
    "electron": "electron .",
    "dist": "electron-builder --win nsis"
  },
  "dependencies": {
    "express": "^5.2.1",
    "mime-types": "^2.1.35",
    "multer": "^2.1.1",
    "qrcode-terminal": "^0.12.0",
    "whatsapp-web.js": "^1.26.0"
  },
  "keywords": [
    "whatsapp",
    "bot",
    "broadcast",
    "whatsapp-web.js"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.techora.whatsapp.broadcast",
    "productName": "Techora WhatsApp Broadcast Bot",
    "win": {
      "target": [
        "nsis"
      ],
      "signAndEditExecutable": false,
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "setup.${ext}",
      "warningsAsErrors": false
    },
    "files": [
      "**/*",
      "!node_modules/electron/**/*",
      "!node_modules/electron-builder/**/*",
      "!cloudflared-windows-amd64.msi",
      "!.git/**/*"
    ],
    "asar": true
  }
}
